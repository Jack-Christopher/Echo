{
  "hotkey": "win+space",
  "fuzzy_threshold": 85,
  "voice_confirmations": true,
  "always_listening": false,
  "search_engine_template": "https://www.google.com/search?q={query}",
  "browser": "brave",
  "browser_path": "",
  "brave_path": "",
  "preferred_volume": 50,
  "whisper_model": "small",
  "whisper_model_path": "",
  "whisper_beam_size": 8,
  "whisper_best_of": 5,
  "whisper_threads": 0,
  "whisper_use_prompt": true,
  "websites": {},
  "link_handlers": {
    "http": { "app": "browser" },
    "https": { "app": "browser" },
    "ftp": { "app": "browser" },
    "ftps": { "app": "browser" },
    "mailto": { "app": "shell" },
    "file": { "app": "shell" }
  },
  "custom_site_searches": [],
  "search_routes": [
    {
      "id": "quiero_ver",
      "label": "Pelicula/Serie (OK.ru)",
      "match": "leading",
      "priority": 200,
      "terms": ["quiero ver"],
      "strip_terms": true,
      "resolve_mode": "site",
      "site_domain": "m.ok.ru"
    },
    {
      "id": "quiero_aprender",
      "label": "Tutorial (YouTube)",
      "match": "leading",
      "priority": 200,
      "terms": ["quiero aprender"],
      "strip_terms": true,
      "resolve_mode": "template",
      "template": "https://www.youtube.com/results?search_query={query}"
    },
    {
      "id": "quiero_escuchar",
      "label": "Musica (YouTube Music)",
      "match": "leading",
      "priority": 200,
      "terms": ["quiero escuchar"],
      "strip_terms": true,
      "resolve_mode": "template",
      "template": "https://music.youtube.com/search?q={query}"
    },
    {
      "id": "general",
      "label": "Busqueda general",
      "match": "fallback",
      "priority": 0,
      "terms": [],
      "resolve_mode": "template",
      "template": "https://www.google.com/search?q={query}"
    }
  ],
  "folders": {
    "descargas": "downloads",
    "documentos": "documents"
  },
  "series": [],
  "routines": {},
  "reminders": []
}
